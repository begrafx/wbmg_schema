<?php

/**
 * @file
 * WBMG Schema Module
 *
 * Version: 0.2.0
 * Description:
 *   Core schema validation system (standalone, framework-level).
 */

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\EntityStorageException;

/**
 * Implements hook_entity_presave().
 */
function wbmg_schema_entity_presave(EntityInterface $entity) {

  // Only process entities that support bundles
  if (!method_exists($entity, 'bundle')) {
    return;
  }

  $resolver = \Drupal::service('wbmg_schema.resolver');
  $validator = \Drupal::service('wbmg_schema.validator');

  $schema_id = $resolver->getSchemaId($entity);

  if (!$schema_id) {
    return;
  }

  $data = [];

  /**
   * ----------------------------------------
   * Extract entity field data
   * ----------------------------------------
   */
  foreach ($entity->getFields() as $field_name => $field) {

    // Handle empty field
    if ($field->isEmpty()) {
      $data[$field_name] = NULL;
      continue;
    }

    // Single value
    if ($field->count() === 1) {
      $item = $field->first();

      if (isset($item->value)) {
        $data[$field_name] = $item->value;
      }
      elseif (isset($item->target_id)) {
        $data[$field_name] = $item->target_id;
      }
      else {
        $data[$field_name] = NULL;
      }
    }

    // Multi-value
    else {
      $values = [];

      foreach ($field as $item) {
        if (isset($item->value)) {
          $values[] = $item->value;
        }
        elseif (isset($item->target_id)) {
          $values[] = $item->target_id;
        }
      }

      $data[$field_name] = $values;
    }
  }

  /**
   * ----------------------------------------
   * Normalize base fields (like title)
   * ----------------------------------------
   */
  if ($entity->hasField('title')) {
    $data['title'] = $entity->getTitle();
  }

  /**
   * ----------------------------------------
   * Run schema validation
   * ----------------------------------------
   */
  $errors = $validator->validate($schema_id, $data);

  if (!empty($errors)) {

    // 🔥 HARD STOP — prevents DB write entirely
    throw new EntityStorageException(
      "WBMG Schema validation failed:\n" . implode("\n", $errors)
    );
  }
}