<?php

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_entity_presave().
 */
function wbmg_schema_entity_presave(EntityInterface $entity) {

  if ($entity->getEntityTypeId() !== 'node') {
    return;
  }

  $bundle = $entity->bundle();

  $validator = \Drupal::service('wbmg_schema.validator');

  $data = [];

  foreach ($entity->getFields() as $field_name => $field) {

    // Handle title (base field)
    if ($field_name === 'title') {
      $value = $entity->label();

      if (empty($value)) {
        throw new \Exception("Required field 'title' is missing.");
      }

      $data[$field_name] = $value;
      continue;
    }

    if ($field->isEmpty()) {
      $data[$field_name] = NULL;
      continue;
    }

    if ($field->count() === 1) {
      $item = $field->first();

      if (isset($item->value)) {
        $data[$field_name] = $item->value;
      }
      elseif (isset($item->target_id)) {
        $data[$field_name] = $item->target_id;
      }
      else {
        $data[$field_name] = NULL;
      }
    }
    else {
      $values = [];

      foreach ($field as $item) {
        if (isset($item->value)) {
          $values[] = $item->value;
        }
        elseif (isset($item->target_id)) {
          $values[] = $item->target_id;
        }
      }

      $data[$field_name] = $values;
    }
  }

  // Debug log
  \Drupal::logger('wbmg_schema')->notice(
    "Schema: @schema\nData:\n<pre>@data</pre>",
    [
      '@schema' => $bundle,
      '@data' => print_r($data, TRUE),
    ]
  );

  // Validate
  $errors = $validator->validate($bundle, $data);

  if (!empty($errors)) {
    throw new \Exception("Schema validation failed:\n" . implode("\n", $errors));
  }
}