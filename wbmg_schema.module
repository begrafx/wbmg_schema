<?php

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_entity_presave().
 */
function wbmg_schema_entity_presave(EntityInterface $entity) {

  if ($entity->getEntityTypeId() !== 'node') {
    return;
  }

  $resolver = \Drupal::service('wbmg_schema.resolver');
  $validator = \Drupal::service('wbmg_schema.validator');

  $schema_id = $resolver->getSchemaId($entity);

  if (!$schema_id) {
    return;
  }

  $data = [];

  foreach ($entity->getFields() as $field_name => $field) {

    // 🔥 SPECIAL HANDLING FOR TITLE (base field)
    if ($field_name === 'title') {
      $data[$field_name] = $entity->label();
      continue;
    }

    if ($field->isEmpty()) {
      $data[$field_name] = NULL;
      continue;
    }

    // Single-value field
    if ($field->count() === 1) {
      $item = $field->first();

      // Some fields don't use ->value (like entity references)
      if (isset($item->value)) {
        $data[$field_name] = $item->value;
      }
      elseif (isset($item->target_id)) {
        $data[$field_name] = $item->target_id;
      }
      else {
        $data[$field_name] = NULL;
      }
    }
    // Multi-value field
    else {
      $values = [];

      foreach ($field as $item) {
        if (isset($item->value)) {
          $values[] = $item->value;
        }
        elseif (isset($item->target_id)) {
          $values[] = $item->target_id;
        }
      }

      $data[$field_name] = $values;
    }
  }

  // 🔍 DEBUG LOG
  \Drupal::logger('wbmg_schema')->notice(
    "Schema: @schema\nData:\n<pre>@data</pre>",
    [
      '@schema' => $schema_id,
      '@data' => print_r($data, TRUE),
    ]
  );

  $errors = $validator->validate($schema_id, $data);

  if (!empty($errors)) {
    throw new \Exception(implode("\n", $errors));
  }
}